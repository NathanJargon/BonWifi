# BonWifi Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=3000
NODE_ENV=production

# GCash Payment Integration (optional)
GCASH_MERCHANT_ID=your_merchant_id
GCASH_API_KEY=your_api_key
GCASH_WEBHOOK_SECRET=your_webhook_secret

# Zero-Cost SMS Forwarder GCash Integration
SMS_WEBHOOK_SECRET=your_secure_webhook_token_here
GCASH_PHONE_NUMBER=09171234567

# WiFi Configuration
WIFI_SSID=BonWifi
WIFI_PASSWORD=BonWifi123!
HOTSPOT_IP=10.0.0.1

# Database
DATABASE_PATH=/opt/BonWifi/bonwifi.db

# Session Settings
SESSION_TIMEOUT=30
MAX_CONCURRENT_SESSIONS=50
